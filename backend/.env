NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/crushcash
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

SQUADCO_SECRET_KEY=sk_xxxxxxxxxxxxxxxx
SQUADCO_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxx
SQUADCO_BASE_URL=https://sandbox-api-d.squadco.com
SQUADCO_WEBHOOK_SECRET=your_webhook_secret

SIGNUP_BONUS=500
REFERRAL_REWARD=50

# Game timing
GAME_DURATION_SECONDS=120
COOLDOWN_DURATION_SECONDS=60

# Anti-cheat
MAX_SCORE_RATE=300
MAX_FLAGS_BEFORE_BAN=3

ADMIN_EMAIL=
ADMIN_PASSWORD

# ─────────────────────────────────────────────
# Email/SMS OTP providers (NOT YET WIRED UP)
# Currently /api/profile/email/send-otp and
# /api/profile/phone/send-otp return the OTP
# directly in the response (devOtp) so the flow
# works end-to-end for demo/testing.
#
# For production, integrate a provider in
# backend/routes/profile.js:
#   Email -> Resend, SendGrid, or Nodemailer+SMTP
#   SMS   -> Termii, Africa's Talking, Twilio
# ─────────────────────────────────────────────
